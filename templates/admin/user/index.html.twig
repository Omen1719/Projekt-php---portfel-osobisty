{% extends 'base.html.twig' %}

{% block title %}{{ 'title.user_list'|trans }}{% endblock %}

{% block body %}
    <h1>{{ 'title.user_list'|trans }}</h1>

    {% if pagination is defined and pagination.items|length %}
        <div class="navigation text-center">{{ knp_pagination_render(pagination) }}</div>

        <table class="table table-striped">
            <thead>
            <tr>
                <th>{{ knp_pagination_sortable(pagination, 'label.id'|trans, 'user.id') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'label.email'|trans, 'user.email') }}</th>
                <th>{{ 'label.role'|trans }}</th>
                <th>{{ 'label.actions'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for user in pagination.items %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td>{{ user.email }}</td>
                    <td>
                        {% for role in user.roles %}
                            {{ ('label.' ~ role|lower)|trans }}{% if not loop.last %}, {% endif %}
                        {% endfor %}
                    </td>
                    <td>
                        <a href="{{ url('admin_user_edit', {id: user.id}) }}"
                           class="btn btn-sm btn-outline-primary" title="{{ 'action.edit'|trans }}">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="{{ url('admin_user_password', {id: user.id}) }}"
                           class="btn btn-sm btn-outline-secondary" title="{{ 'action.set_password'|trans }}">
                            <i class="bi bi-key"></i>
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="navigation text-center">{{ knp_pagination_render(pagination) }}</div>
    {% else %}
        <p>{{ 'message.empty_list'|trans }}</p>
    {% endif %}
{% endblock %}
