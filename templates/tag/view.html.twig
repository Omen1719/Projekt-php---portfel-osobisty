{% extends 'base.html.twig' %}

{% block title %}{{ 'title.tag_details'|trans({'%id%': tag.id|default('')}) }}{% endblock %}

{% block body %}
    <h1>{{ 'title.tag_details'|trans({'%id%': tag.id|default('')}) }}</h1>
    {% if tag is defined and tag.id %}
        <dl class="dl-horizontal">
            <dt>{{ 'label.id'|trans }}</dt><dd>{{ tag.id }}</dd>
            <dt>{{ 'label.created_at'|trans }}</dt><dd>{{ tag.createdAt|format_date('long') }}</dd>
            <dt>{{ 'label.updated_at'|trans }}</dt><dd>{{ tag.updatedAt|format_date('long') }}</dd>
            <dt>{{ 'label.title'|trans }}</dt><dd>{{ tag.title }}</dd>
            <dt>{{ 'label.slug'|trans }}</dt><dd>{{ tag.slug }}</dd>
        </dl>
        <p>
            <a href="{{ url('tag_edit', {id: tag.id}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'action.edit'|trans }}">
                <i class="bi bi-pencil"></i> {{ 'action.edit'|trans }}
            </a>
            <a href="{{ url('tag_delete', {id: tag.id}) }}" class="btn btn-sm btn-outline-danger" title="{{ 'action.delete'|trans }}">
                <i class="bi bi-trash"></i> {{ 'action.delete'|trans }}
            </a>
            <a href="{{ url('tag_index') }}" class="btn btn-sm btn-secondary" title="{{ 'action.back_to_list'|trans }}">
                <i class="bi bi-arrow-left"></i> {{ 'action.back_to_list'|trans }}
            </a>
        </p>
    {% else %}
        <p>{{ 'message.record_not_found'|trans }}</p>
    {% endif %}
{% endblock %}
