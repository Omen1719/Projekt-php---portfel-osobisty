{% extends 'base.html.twig' %}

{% block title %}{{ 'title.wallet_details'|trans({'%id%': wallet.id|default('')}) }}{% endblock %}

{% block body %}
    <h1>{{ 'title.wallet_details'|trans({'%id%': wallet.id|default('')}) }}</h1>
    {% if wallet is defined and wallet.id %}
        <dl class="dl-horizontal">
            <dt>{{ 'label.id'|trans }}</dt><dd>{{ wallet.id }}</dd>
            <dt>{{ 'label.title'|trans }}</dt><dd>{{ wallet.title }}</dd>
            <dt>{{ 'label.wallet_type'|trans }}</dt><dd>{{ ('label.wallet_' ~ wallet.type)|trans }}</dd>
            <dt>{{ 'label.balance'|trans }}</dt><dd>{{ balance|number_format(2, '.', ' ') }}</dd>
            <dt>{{ 'label.created_at'|trans }}</dt><dd>{{ wallet.createdAt|format_date('long') }}</dd>
            <dt>{{ 'label.updated_at'|trans }}</dt><dd>{{ wallet.updatedAt|format_date('long') }}</dd>
        </dl>
        <p>
            <a href="{{ url('wallet_edit', {id: wallet.id}) }}" class="btn btn-sm btn-outline-primary" title="{{ 'action.edit'|trans }}">
                <i class="bi bi-pencil"></i> {{ 'action.edit'|trans }}
            </a>
            {% if can_be_deleted is defined and can_be_deleted %}
                <a href="{{ url('wallet_delete', {id: wallet.id}) }}" class="btn btn-sm btn-outline-danger" title="{{ 'action.delete'|trans }}">
                    <i class="bi bi-trash"></i> {{ 'action.delete'|trans }}
                </a>
            {% endif %}
            <a href="{{ url('wallet_index') }}" class="btn btn-sm btn-secondary" title="{{ 'action.back_to_list'|trans }}">
                <i class="bi bi-arrow-left"></i> {{ 'action.back_to_list'|trans }}
            </a>
        </p>
    {% else %}
        <p>{{ 'message.record_not_found'|trans }}</p>
    {% endif %}
{% endblock %}
