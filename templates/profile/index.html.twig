{% extends 'base.html.twig' %}

{% block title %}{{ 'title.profile'|trans }}{% endblock %}

{% block body %}
    <h1>{{ 'title.profile'|trans }}</h1>

    <dl class="dl-horizontal">
        <dt>{{ 'label.email'|trans }}</dt><dd>{{ user.email }}</dd>
        <dt>{{ 'label.role'|trans }}</dt>
        <dd>
            {% for role in user.roles %}
                {{ ('label.' ~ role|lower)|trans }}{% if not loop.last %}, {% endif %}
            {% endfor %}
        </dd>
    </dl>

    <p>
        <a href="{{ url('profile_edit') }}" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-pencil"></i> {{ 'action.edit_profile'|trans }}
        </a>
        <a href="{{ url('profile_password') }}" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-key"></i> {{ 'action.change_password'|trans }}
        </a>
    </p>
{% endblock %}
