<!DOCTYPE html>
<html lang="{{ app.request.locale|default('pl') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="icon" href="{{ asset('favicon.svg') }}">
        <title>{% block title %}{{ 'title.app'|trans }}{% endblock %}</title>
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
                  rel="stylesheet" crossorigin="anonymous">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
                  rel="stylesheet">
            <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" href="{{ path('home') }}">{{ 'title.app'|trans }}</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    {% if app.user %}
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('wallet_index') }}">{{ 'nav.wallets'|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('operation_index') }}">{{ 'nav.operations'|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('category_index') }}">{{ 'nav.categories'|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('tag_index') }}">{{ 'nav.tags'|trans }}</a>
                            </li>
                            {% if is_granted('ROLE_ADMIN') %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('admin_user_index') }}">{{ 'nav.admin'|trans }}</a>
                                </li>
                            {% endif %}
                        </ul>
                    {% endif %}
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        {% if app.user %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('profile_index') }}">{{ app.user.email }}</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_logout') }}">{{ 'action.logout'|trans }}</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">{{ 'action.login'|trans }}</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_register') }}">{{ 'action.register'|trans }}</a>
                            </li>
                        {% endif %}
                        <li class="nav-item d-flex align-items-center ms-lg-3">
                            <a class="nav-link py-0 px-1 {{ app.request.locale == 'pl' ? 'fw-bold' : '' }}" href="?_locale=pl">PL</a>
                            <span class="text-secondary">|</span>
                            <a class="nav-link py-0 px-1 {{ app.request.locale == 'en' ? 'fw-bold' : '' }}" href="?_locale=en">EN</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        <main role="main" class="container-fluid">
            {% include 'default/_flash_messages.html.twig' %}
            {% block body %}{% endblock %}
        </main>
        {% block javascripts %}
            <script src="https://code.jquery.com/jquery-3.7.1.slim.min.js" crossorigin="anonymous"></script>
            <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" crossorigin="anonymous"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js" crossorigin="anonymous"></script>
        {% endblock %}
    </body>
</html>
