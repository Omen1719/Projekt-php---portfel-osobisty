{% extends 'base.html.twig' %}

{% block title %}{{ 'title.app'|trans }}{% endblock %}

{% block body %}
    <div class="px-4 py-5 my-3 text-center">
        <h1 class="display-5 fw-bold">{{ 'title.app'|trans }}</h1>
    </div>

    <div class="row g-4">
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title">{{ 'nav.wallets'|trans }}</h5>
                    <a href="{{ path('wallet_index') }}" class="btn btn-primary mt-3">{{ 'action.go'|trans }}</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title">{{ 'nav.operations'|trans }}</h5>
                    <a href="{{ path('operation_index') }}" class="btn btn-primary mt-3">{{ 'action.go'|trans }}</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title">{{ 'nav.categories'|trans }}</h5>
                    <a href="{{ path('category_index') }}" class="btn btn-primary mt-3">{{ 'action.go'|trans }}</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title">{{ 'nav.tags'|trans }}</h5>
                    <a href="{{ path('tag_index') }}" class="btn btn-primary mt-3">{{ 'action.go'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
